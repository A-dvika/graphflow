        <mxCell id="c-subtitle" value="GraphFlow does not replace CI/CD. It ingests pipeline events, evaluates release-flow risk, and returns production gate decisions with audit evidence." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;fontSize=14;fontColor=#334155;spacing=12;" vertex="1" parent="1">
