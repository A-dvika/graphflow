  </diagram>

  <diagram id="data-model" name="4. Data Model And Evidence">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="d-title" value="GraphFlow Data Model And Evidence Flow&#xa;Why Aurora + DynamoDB both matter" style="text;html=1;strokeColor=none;fillColor=none;align=left;whiteSpace=wrap;fontSize=27;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1">
          <mxGeometry x="50" y="30" width="960" height="64" as="geometry" />
        </mxCell>

        <mxCell id="d-identity" value="RunIdentity&#xa;&#xa;tenantId&#xa;projectId&#xa;workflowId&#xa;runId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontSize=15;fontStyle=1;fontColor=#334155;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="80" y="180" width="210" height="160" as="geometry" />
        </mxCell>

        <mxCell id="d-workflow" value="Aurora graph tables&#xa;&#xa;workflows&#xa;workflow_nodes&#xa;workflow_edges&#xa;&#xa;Stable topology, durations, positions, node types" style="shape=cylinder3d;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fef3c7;strokeColor=#d97706;fontSize=13;fontColor=#78350f;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="410" y="150" width="250" height="190" as="geometry" />
        </mxCell>

        <mxCell id="d-run" value="DynamoDB run state&#xa;&#xa;pk = TENANT#...#PROJECT#...#RUN#...&#xa;sk = META&#xa;sk = NODE#{nodeId}&#xa;&#xa;Write-heavy live status updates" style="shape=cylinder3d;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=13;fontColor=#0c4a6e;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="780" y="150" width="270" height="210" as="geometry" />
        </mxCell>

        <mxCell id="d-policy" value="Release policy&#xa;&#xa;required node types&#xa;fail-on node types&#xa;approval-before-deploy&#xa;migration-risk blocking" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontSize=14;fontColor=#14532d;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1190" y="170" width="250" height="170" as="geometry" />
        </mxCell>

        <mxCell id="d-gate" value="GateDecision&#xa;&#xa;verdict: PASS / WARN / FAIL&#xa;shouldBlock&#xa;reasons&#xa;failedNodes / blockedNodes / waitingNodes&#xa;blastRadius&#xa;criticalPath&#xa;migrationRisk&#xa;policy snapshot" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;fontSize=14;fontStyle=1;fontColor=#7f1d1d;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="470" y="500" width="320" height="260" as="geometry" />
        </mxCell>

        <mxCell id="d-audit" value="Aurora audit evidence&#xa;&#xa;release_audit_events&#xa;release_audit_summary&#xa;&#xa;actor, node, status, message, metadata, timestamp" style="shape=cylinder3d;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffedd5;strokeColor=#f97316;fontSize=13;fontColor=#7c2d12;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="920" y="520" width="270" height="210" as="geometry" />
        </mxCell>

        <mxCell id="d-export" value="Compliance export&#xa;&#xa;/api/runs/{runId}/compliance&#xa;&#xa;Graph summary&#xa;Gate decision&#xa;Policy evidence&#xa;Migration risk&#xa;Run state&#xa;Audit events&#xa;SOC 2 / PCI evidence flags" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#9333ea;fontSize=14;fontStyle=1;fontColor=#581c87;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="1240" y="500" width="260" height="260" as="geometry" />
        </mxCell>

        <mxCell id="d-note" value="Design decision&#xa;&#xa;Aurora is used for stable, queryable graph and audit/evidence data.&#xa;DynamoDB is used for high-volume live run state and fast CI event writes.&#xa;The release gate composes both into one deterministic decision." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontSize=16;fontColor=#334155;spacing=16;" vertex="1" parent="1">
          <mxGeometry x="120" y="840" width="1360" height="100" as="geometry" />
        </mxCell>

        <mxCell id="d-e1" value="addresses all data" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#64748b;fontColor=#334155;endArrow=block;endFill=1;" edge="1" parent="1" source="d-identity" target="d-workflow">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d-e2" value="addresses all data" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#64748b;fontColor=#334155;endArrow=block;endFill=1;" edge="1" parent="1" source="d-identity" target="d-run">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d-e3" value="graph topology" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d97706;fontColor=#78350f;endArrow=block;endFill=1;" edge="1" parent="1" source="d-workflow" target="d-gate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d-e4" value="node statuses" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#0284c7;fontColor=#0c4a6e;endArrow=block;endFill=1;" edge="1" parent="1" source="d-run" target="d-gate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d-e5" value="org rules" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#16a34a;fontColor=#14532d;endArrow=block;endFill=1;" edge="1" parent="1" source="d-policy" target="d-gate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d-e6" value="ingest writes evidence" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#f97316;fontColor=#7c2d12;endArrow=block;endFill=1;" edge="1" parent="1" source="d-run" target="d-audit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d-e7" value="decision evidence" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#dc2626;fontColor=#7f1d1d;endArrow=block;endFill=1;" edge="1" parent="1" source="d-gate" target="d-export">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d-e8" value="audit trail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#f97316;fontColor=#7c2d12;endArrow=block;endFill=1;" edge="1" parent="1" source="d-audit" target="d-export">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
