  <diagram id="sequence" name="3. Live Demo Flow">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="s-title" value="Live Demo Flow&#xa;How we prove the UI is not dummy" style="text;html=1;strokeColor=none;fillColor=none;align=left;whiteSpace=wrap;fontSize=27;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1">
          <mxGeometry x="50" y="30" width="840" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s-step1" value="1&#xa;Run demo command&#xa;npm run graphflow:demo:fail-security" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=14;fontStyle=1;fontColor=#78350f;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="180" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="s-step2" value="2&#xa;Register workflow&#xa;POST /api/workflows/register&#xa;checkout-release-v1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontSize=14;fontStyle=1;fontColor=#14532d;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="360" y="180" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="s-step3" value="3&#xa;Ingest node events&#xa;POST /api/ingest/gitlab&#xa;build, unit, integration, dependency scan, static scan" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfeff;strokeColor=#0891b2;fontSize=14;fontStyle=1;fontColor=#164e63;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="640" y="180" width="240" height="130" as="geometry" />
        </mxCell>
        <mxCell id="s-step4" value="4&#xa;Security node fails&#xa;static_scan = failed&#xa;Downstream nodes become blocked by graph traversal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=14;fontStyle=1;fontColor=#7f1d1d;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="940" y="180" width="240" height="130" as="geometry" />
        </mxCell>
        <mxCell id="s-step5" value="5&#xa;Call release gate&#xa;GET /api/runs/{runId}/gate&#xa;Returns HTTP 409 + FAIL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;fontSize=14;fontStyle=1;fontColor=#7f1d1d;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1240" y="180" width="230" height="130" as="geometry" />
        </mxCell>

        <mxCell id="s-dashboard" value="Open printed dashboard URL&#xa;&#xa;Graph shows actual runId&#xa;Failed static_scan&#xa;Blocked approval/staging/smoke/canary/prod path&#xa;Policy and migration-risk evidence&#xa;Agent explanation and logs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=16;fontStyle=1;fontColor=#1e3a8a;spacing=16;" vertex="1" parent="1">
          <mxGeometry x="190" y="440" width="520" height="230" as="geometry" />
        </mxCell>

        <mxCell id="s-compliance" value="Compliance export&#xa;GET /api/runs/{runId}/compliance&#xa;&#xa;Includes graph summary, gate decision, policy snapshot, run state, migration risk, audit evidence flags" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontSize=15;fontColor=#334155;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="860" y="450" width="500" height="210" as="geometry" />
        </mxCell>

        <mxCell id="s-line" value="Demo sentence&#xa;This is not a mocked dashboard. We generated this run through the same API GitLab uses, and GraphFlow produced a real production-blocking gate decision." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=17;fontStyle=1;fontColor=#14532d;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="130" y="780" width="1340" height="100" as="geometry" />
        </mxCell>

        <mxCell id="s-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#64748b;endArrow=block;endFill=1;" edge="1" parent="1" source="s-step1" target="s-step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#64748b;endArrow=block;endFill=1;" edge="1" parent="1" source="s-step2" target="s-step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s-e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#64748b;endArrow=block;endFill=1;" edge="1" parent="1" source="s-step3" target="s-step4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s-e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#64748b;endArrow=block;endFill=1;" edge="1" parent="1" source="s-step4" target="s-step5">
          <mxGeometry relative="1" as="geometry" />
